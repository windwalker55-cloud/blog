<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="/styles/header.css">


<header class="masthead">
  <div class="masthead-inner">
    <a href="/homepage" class="wordmark">
      <span class="mark">L</span>Logo
    </a>

    <div class="nav-actions">
      <div class="desktop-auth">
        <% if (userInfo) { %>
          <a href="/login" class="signin-link"><%= userInfo.username %></a>
          <a href="/logout" class="subscribe-btn">logout</a>
        <% } %>
        <% if (!userInfo) { %>
          <a href="/login" class="signin-link">Sign in</a>
          <a href="/signup"><button class="subscribe-btn">Signup</button></a>
        <% } %>
      </div>

      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <nav class="section-nav">
    <ul class="nav-menu" id="navMenu">
      <li><a href="/homepage" class="active">Home</a></li>
      <li><a href="/world">World</a></li>
      <li><a href="/politics">Politics</a></li>
      <li><a href="/entertainment">Entertainments</a></li>
      <li><a href="/sports">Sports</a></li>
      <li><a href="/tech">Technology</a></li>
      <li><a href="/health">Health</a></li>
      <li><a href="/culture">Culture</a></li>
      <li><a href="/about">About</a></li>
      <li class="auth-mobile-item">
        <% if (userInfo) { %>
          <a href="/login" class="signin-link"><%= userInfo.username %></a>
          <a href="/logout" class="subscribe-btn">Logout</a>
        <% } %>
        <% if (!userInfo) { %>
          <a href="/login" class="signin-link">Sign in</a>
          <a href="/signup" class="subscribe-btn">Signup</a>
        <% } %>
      </li>
    </ul>
  </nav>
</header>
<script src="/js/header.js"></script>