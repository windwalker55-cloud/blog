<!-- ====== ABOUT PAGE MAIN CONTENT ONLY ====== -->
<style>
  :root{
    --ink:#15181F;
    --ink-soft:#2B3040;
    --paper:#FBFAF7;
    --paper-dim:#F1EFE9;
    --rule:#D9D4C6;
    --press:#A3311F;
    --grey:#5B5E66;
    --grey-light:#8A8D93;
  }
  
  .eyebrow{
    font-family:'Inter',sans-serif;
    font-size:.72rem;
    font-weight:700;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--press);
  }

  .photo{
    position:relative;
    background:linear-gradient(155deg, var(--ink) 0%, var(--ink-soft) 55%, var(--press) 130%);
    overflow:hidden;
  }
  .photo::before{
    content:'';
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 30% 25%, rgba(255,255,255,.10), transparent 45%),
      radial-gradient(circle at 75% 70%, rgba(255,255,255,.06), transparent 50%);
  }
  .photo::after{
    content:attr(data-cap);
    position:absolute;
    left:.9rem;
    bottom:.8rem;
    font-family:'Inter',sans-serif;
    font-size:.66rem;
    letter-spacing:.03em;
    color:rgba(251,250,247,.75);
  }

  .wrap{max-width:1280px;margin:0 auto;padding:0 2.4rem;}
  @media screen and (max-width:900px){.wrap{padding:0 1.4rem;}}

  /* ===== hero ===== */
  .about-hero{
    max-width:900px;
    margin:3.4rem auto 0;
    padding-bottom:3rem;
    border-bottom:1px solid var(--rule);
    text-align:center;
  }
  .about-hero .eyebrow{display:block;margin-bottom:1rem;}
  .about-hero h1{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(2.4rem,4.6vw,3.6rem);
    line-height:1.1;
    letter-spacing:-.015em;
    margin:0 auto 1.2rem;
  }
  .about-hero h1 em{
    font-style:italic;
    font-weight:500;
    color:var(--press);
  }
  .about-hero p{
    font-size:1.18rem;
    color:var(--ink-soft);
    max-width:56ch;
    margin:0 auto;
  }

  /* ===== charter / mission ===== */
  .mission{padding:3.4rem 0;border-bottom:1px solid var(--rule);}
  .mission-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:3rem;
    align-items:center;
  }
  .mission-text .eyebrow{display:block;margin-bottom:.9rem;}
  .mission-text h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.9rem;
    line-height:1.18;
    letter-spacing:-.01em;
    margin-bottom:1.1rem;
  }
  .mission-text p{
    font-size:1.05rem;
    color:var(--ink-soft);
    margin-bottom:1rem;
    max-width:52ch;
  }
  .mission-photo .photo{height:340px;border-radius:1px;}
  @media screen and (max-width:900px){
    .mission-grid{grid-template-columns:1fr;}
    .mission-photo .photo{height:220px;}
  }

  /* ===== principles ===== */
  .principles{padding:3.4rem 0;border-bottom:1px solid var(--rule);}
  .section-head{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    border-bottom:1px solid var(--ink);
    padding-bottom:.9rem;
    margin-bottom:2.2rem;
    flex-wrap:wrap;
    gap:.6rem;
  }
  .section-head h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.7rem;
  }
  .section-head span{
    font-family:'Inter',sans-serif;
    font-size:.78rem;
    color:var(--grey);
    letter-spacing:.03em;
  }
  .principles-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(230px, 1fr));
    gap:0;
  }
  .principle{
    padding:0 1.8rem 0 0;
    border-right:1px solid var(--rule);
    margin-right:1.8rem;
  }
  .principle:last-child{
    border-right:none;
    margin-right:0;
    padding-right:0;
  }
  .principle i{
    color:var(--press);
    font-size:1.3rem;
    margin-bottom:.9rem;
    display:block;
  }
  .principle h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.15rem;
    margin-bottom:.55rem;
  }
  .principle p{
    font-size:.94rem;
    color:var(--grey);
    line-height:1.55;
  }
  @media screen and (max-width:860px){
    .principle{
      border-right:none;
      border-bottom:1px solid var(--rule);
      padding:0 0 1.6rem;
      margin:0 0 1.6rem;
    }
  }

  /* ===== timeline ===== */
  .timeline{padding:3.4rem 0;border-bottom:1px solid var(--rule);}
  .timeline-list{max-width:760px;}
  .timeline-item{
    display:grid;
    grid-template-columns:110px 1fr;
    gap:1.6rem;
    padding:1.6rem 0;
    border-top:1px solid var(--rule);
  }
  .timeline-item:first-child{border-top:none;}
  .timeline-year{
    font-family:'Fraunces', serif;
    font-weight:700;
    font-size:1.5rem;
    color:var(--press);
  }
  .timeline-item h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.1rem;
    margin-bottom:.4rem;
  }
  .timeline-item p{
    font-size:.95rem;
    color:var(--ink-soft);
  }
  @media screen and (max-width:600px){
    .timeline-item{grid-template-columns:1fr;gap:.4rem;}
  }

  /* ===== masthead team ===== */
  .team{padding:3.4rem 0;border-bottom:1px solid var(--rule);}
  .team-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
    gap:1.8rem;
  }
  .team-card .avatar{
    width:64px;
    height:64px;
    border-radius:50%;
    margin-bottom:1rem;
    background:linear-gradient(155deg, var(--ink), var(--press));
    display:flex;
    align-items:center;
    justify-content:center;
    color:var(--paper);
    font-family:'Fraunces', serif;
    font-weight:700;
    font-size:1.3rem;
  }
  .team-card h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.1rem;
    margin-bottom:.2rem;
  }
  .team-card .role{
    font-family:'Inter',sans-serif;
    font-size:.76rem;
    font-weight:600;
    letter-spacing:.03em;
    text-transform:uppercase;
    color:var(--press);
    margin-bottom:.6rem;
    display:block;
  }
  .team-card p{
    font-size:.92rem;
    color:var(--grey);
  }

  /* ===== stats ===== */
  .stats{
    background:var(--ink);
    color:var(--paper);
    margin:0 -2.4rem;
    padding:0 2.4rem;
  }
  .stats-inner{
    max-width:1280px;
    margin:0 auto;
    padding:2.6rem 0;
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(160px,1fr));
    gap:1.6rem;
  }
  .stat .num{
    font-family:'Fraunces', serif;
    font-weight:700;
    font-size:2.2rem;
    color:#EADFC8;
  }
  .stat .label{
    font-family:'Inter',sans-serif;
    font-size:.76rem;
    letter-spacing:.04em;
    text-transform:uppercase;
    color:#9CA0AC;
    margin-top:.3rem;
  }
  @media screen and (max-width:900px){
    .stats{margin:0 -1.4rem;padding:0 1.4rem;}
  }

  /* ===== support / CTA ===== */
  .support{padding:3.6rem 0;text-align:center;}
  .support h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:2rem;
    margin-bottom:1rem;
    max-width:640px;
    margin-left:auto;
    margin-right:auto;
  }
  .support p{
    font-size:1.05rem;
    color:var(--ink-soft);
    max-width:56ch;
    margin:0 auto 1.8rem;
  }
  .support-actions{
    display:flex;
    justify-content:center;
    gap:1rem;
    flex-wrap:wrap;
    font-family:'Inter',sans-serif;
  }
  .btn-primary{
    background:var(--ink);
    color:var(--paper);
    border:none;
    padding:.85rem 1.9rem;
    font-weight:600;
    font-size:.85rem;
    letter-spacing:.02em;
    cursor:pointer;
    border-radius:2px;
    display:inline-flex;
    align-items:center;
    gap:.6rem;
    transition:.15s;
  }
  .btn-primary:hover{background:var(--press);}
  .btn-outline{
    background:none;
    border:1.5px solid var(--ink);
    color:var(--ink);
    padding:.78rem 1.7rem;
    font-weight:600;
    font-size:.85rem;
    letter-spacing:.02em;
    cursor:pointer;
    border-radius:2px;
    display:inline-flex;
    align-items:center;
    gap:.6rem;
    transition:.15s;
  }
  .btn-outline:hover{border-color:var(--press);color:var(--press);}
</style>

<!-- ===== ABOUT PAGE MAIN CONTENT ===== -->
<div class="wrap">

  <section class="about-hero">
    <span class="eyebrow">About Our Blog</span>
    <h1>Stories that <em>matter</em>, written with care.</h1>
    <p>The BlogPost is an independent, reader-supported publication. We take the time each story deserves — depth over speed, context over noise, and thoughtful writing over clickbait.</p>
