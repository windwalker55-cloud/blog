<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="styles/signup.css">


<header class="masthead">
  <a href="#" class="wordmark">
    <span class="mark">L</span>Logo
  </a>
</header>

<main>
  <section class="panel-left">
    <span class="eyebrow">Join Logo</span>
    <h1>Reporting worth a <em>subscription</em>.</h1>
    <p>Create a free account to save stories, follow topics, and support a newsroom with no corporate advertisers steering the coverage.</p>

    <ul class="benefits">
      <li><i class="fas fa-check"></i> Unlimited access to daily reporting</li>
      <li><i class="fas fa-check"></i> Save and revisit stories across devices</li>
      <li><i class="fas fa-check"></i> Weekly editor's briefing by email</li>
      <li><i class="fas fa-check"></i> Comment and join reader discussions</li>
    </ul>
  </section>

  <section class="panel-right">
    <div class="form-head">
      <h2>Create your account</h2>
      <p>Already a member? <a href="/login">Sign in</a></p>
    </div>

    <% if (detailsTaken) { %>
      <div class="error-message">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= detailsTaken %></span>
      </div>
    <% } %>

    <form id="signupForm" method="POST" action="/signup" novalidate>
      <div class="field">
        <label for="email">Email address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
        <div class="field-error" id="emailError">Enter a valid email address.</div>
      </div>

      <div class="field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="windwalker" required>
        <div class="field-error" id="usernameError">Enter a valid username.</div>
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Min 6 characters" required>
        <div class="field-error" id="passwordError">Password must be at least 6 characters.</div>
      </div>

      <div class="field">
        <label for="confirmPassword">Confirm password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter your password" required>
        <div class="field-error" id="confirmError">Passwords do not match.</div>
      </div>

      <label class="terms">
        <input type="checkbox" id="terms" required>
        <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.</span>
      </label>

      <button type="submit" class="btn-primary">
        Create account <i class="fas fa-arrow-right"></i>
      </button>

      <div class="divider">or</div>

      <button type="button" class="btn-outline">
        <i class="fab fa-google"></i> Continue with Google
      </button>
    </form>
  </section>
</main>

<footer>
  <i class="far fa-copyright"></i> Logo
</footer>

<script src="js/signup.js"> </script>