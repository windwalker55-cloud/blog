<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="styles/login.css">

<header class="masthead">
  <a href="/" class="wordmark">
    <span class="mark">L</span>Logo
  </a>
</header>

<main>
  <section class="panel-left">
    <span class="eyebrow">Reader Access</span>
    <h1>Welcome back to the <em>newsroom</em>.</h1>
    <p>Sign in to continue reading, pick up saved stories, and manage your subscription — all without an algorithm deciding what you see.</p>
    <div class="panel-quote">
      <p>"Good journalism doesn't chase the story of the day. It decides, patiently, which stories are worth telling well."</p>
      <cite>— Newsroom Charter</cite>
    </div>
  </section>

  <section class="panel-right">
    <div class="form-head">
      <h2>Sign in</h2>
      <p>New to ....? <a href="/signup">Create an account</a></p>
    </div>

    <% if (incorrectEmail || incorrectPassword) { %>
      <div class="error-message">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= incorrectEmail || incorrectPassword %></span>
      </div>
    <% } %>

    <form id="loginForm" method="POST" action="/login" novalidate>
      <div class="field">
        <label for="email">Email address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
        <div class="field-error" id="emailError">Enter a valid email address.</div>
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>
        <div class="field-error" id="passwordError">Password is required.</div>
      </div>

      <div class="row-between">
        <label class="remember">
          <input type="checkbox" name="remember"> Keep me signed in
        </label>
        <a href="#" class="forgot">Forgot password?</a>
      </div>

      <button type="submit" class="btn-primary">
        Sign in <i class="fas fa-arrow-right"></i>
      </button>

      <div class="divider">or</div>

      <button type="button" class="btn-outline">
        <i class="fab fa-google"></i> Continue with Google
      </button>
    </form>
  </section>
</main>

<footer>
  <i class="far fa-copyright"></i> 2026 The ... — Independent Newsroom
</footer>

<script src="js/login.js"></script>